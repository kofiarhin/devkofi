NODE_ENV=development
PORT=5000

MONGO_URI=

CLIENT_URL=http://localhost:5173

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
CONTACT_TO_EMAIL=your@email.com
CONTACT_RATE_LIMIT=5
NEWSLETTER_RATE_LIMIT=5
NEWSLETTER_VERIFY_RATE_LIMIT=30
# Set to "true" only in dev when corporate/antivirus TLS interception causes
# "self-signed certificate in certificate chain" from nodemailer.
SMTP_ALLOW_SELF_SIGNED=false

# Optional server-side Telegram admin notifications
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_strong_password
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
